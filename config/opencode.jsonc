{
  "plugin": ["oh-my-openagent"],
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "AGENTS.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "permission": {
    "*": "allow",
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "allow"
  },
  "agent": {
    "caveman": {
      "description": "Ultra-fast, zero-fluff coding agent. Caveman mode.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0,
      "color": "#ff6b6b",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "doom_loop": "allow"
      }
    },
    "security-auditor": {
      "description": "Audits code for vulnerabilities and security issues",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0,
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "grep": "allow",
        "read": "allow"
      }
    },
    "docs-writer": {
      "description": "Writes documentation only",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "read": "allow"
      }
    },
    "refactor": {
      "description": "Aggressive code refactoring and cleanup",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "grep": "allow",
        "glob": "allow",
        "lsp": "allow"
      }
    }
  }
}