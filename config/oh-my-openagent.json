{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "oracle": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "librarian": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "multimodal-looker": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "prometheus": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "metis": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "momus": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "atlas": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "sisyphus-junior": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "deep": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "artistry": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "quick": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "unspecified-low": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "writing": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "google_auth": false,
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 8,
    "tmux_visualization": false
  },
  "agent_order": ["sisyphus", "hephaestus", "prometheus", "atlas"],
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "hashline_edit": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 30,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "background_task": {
    "defaultConcurrency": 8,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "opencode-go": 5,
      "anthropic": 3,
      "google": 5
    },
    "mcp": {
      "servers": {
        "web-search": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-tavily"],
          "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" }
        },
        "pdf-reader": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-pdf"],
          "description": "Read and analyze PDF documents"
        },
        "google-drive": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-gdrive"],
          "description": "Access files in Google Drive"
        },
        "memory-plus": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-memory"],
          "description": "Advanced graph-based memory"
        }
      }
    },
    "modelConcurrency": {
      "opencode-go/deepseek-v4-flash": 5
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true,
    "task_system": true,
    "parallel_discovery": true,
    "streaming_tools": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 10
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  }
}
